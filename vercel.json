{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",        "destination": "/stockr_frontend/www2/index.html" },
    { "source": "/sw.js",   "destination": "/stockr_frontend/www2/sw.js" },
    { "source": "/manifest.json", "destination": "/stockr_frontend/www2/manifest.json" },
    { "source": "/app.js",  "destination": "/stockr_frontend/www2/app.js" },
    { "source": "/styles.css", "destination": "/stockr_frontend/www2/styles.css" },
    { "source": "/icons/:path*", "destination": "/stockr_frontend/www2/icons/:path*" },
    { "source": "/:path*",  "destination": "/stockr_frontend/www2/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" }
      ]
    }
  ]
}
